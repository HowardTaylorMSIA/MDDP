/// Salesperson dimension table with personnel identifiers and names.
table Salesperson
	lineageTag: 1beb30fa-c09b-4e84-acd3-de8ab3edc3aa
	sourceLineageTag: [Gold].[Salesperson]

	/// Hidden; primary key for the salesperson, used as relationship key
	column PersonID
		dataType: int64
		isHidden
		formatString: 0
		sourceProviderType: int
		lineageTag: 631593c9-48db-48de-b8d4-19f788808f2b
		sourceLineageTag: PersonID
		summarizeBy: none
		sourceColumn: PersonID

		annotation SummarizationSetBy = Automatic

	/// Full name of the salesperson
	column FullName
		dataType: string
		sourceProviderType: varchar(50)
		lineageTag: 3d32b554-8389-47b3-b3d6-123389f25cbb
		sourceLineageTag: FullName
		summarizeBy: none
		sourceColumn: FullName

		annotation SummarizationSetBy = Automatic

	partition Salesperson = entity
