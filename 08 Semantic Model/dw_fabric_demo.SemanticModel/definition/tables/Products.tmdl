/// Product dimension table with stock item details, supplier and brand information.
table Products
	lineageTag: 807d838a-5f57-44af-9b53-d790106e8b15
	sourceLineageTag: [Gold].[Products]

	/// Hidden; primary key for the product, used as relationship key
	column StockItemID
		dataType: int64
		isHidden
		formatString: 0
		sourceProviderType: int
		lineageTag: 8f8acd77-ebbd-48c1-b74d-04e15bc9f588
		sourceLineageTag: StockItemID
		summarizeBy: none
		sourceColumn: StockItemID

		annotation SummarizationSetBy = Automatic

	/// Name of the stock item or product
	column StockItemName
		dataType: string
		sourceProviderType: varchar(100)
		lineageTag: 6f6b6574-71b7-484c-ae41-5323d55abcbd
		sourceLineageTag: StockItemName
		summarizeBy: none
		sourceColumn: StockItemName

		annotation SummarizationSetBy = Automatic

	/// Hidden; foreign key to supplier, used as relationship key
	column SupplierID
		dataType: int64
		isHidden
		formatString: 0
		sourceProviderType: int
		lineageTag: 4aef82c1-86e8-4973-8e68-965ed1c85175
		sourceLineageTag: SupplierID
		summarizeBy: none
		sourceColumn: SupplierID

		annotation SummarizationSetBy = Automatic

	/// Name of the supplier for this product
	column SupplierName
		dataType: string
		sourceProviderType: varchar(100)
		lineageTag: 6aca4e10-21cc-40dc-8d75-b1e5ec09d377
		sourceLineageTag: SupplierName
		summarizeBy: none
		sourceColumn: SupplierName

		annotation SummarizationSetBy = Automatic

	/// Brand name of the product
	column Brand
		dataType: string
		sourceProviderType: varchar(20)
		lineageTag: a1d43f7c-9f1d-45f9-aade-65d49ebaa60e
		sourceLineageTag: Brand
		summarizeBy: none
		sourceColumn: Brand

		annotation SummarizationSetBy = Automatic

	/// Color of the product
	column ColorName
		dataType: string
		sourceProviderType: varchar(20)
		lineageTag: 60056120-31b3-4d92-b951-9639d37a7767
		sourceLineageTag: ColorName
		summarizeBy: none
		sourceColumn: ColorName

		annotation SummarizationSetBy = Automatic

	/// Supplier lead time in days for restocking this product
	column LeadTimeDays
		dataType: int64
		formatString: 0
		sourceProviderType: int
		lineageTag: 429ab6a6-89d2-4b51-bb07-2871a204b50e
		sourceLineageTag: LeadTimeDays
		summarizeBy: none
		sourceColumn: LeadTimeDays

		annotation SummarizationSetBy = Automatic

	hierarchy 'Product Hierarchy'
		lineageTag: c3d4e5f6-3333-4444-5555-666677778888

		level Supplier
			lineageTag: c3d4e5f6-3333-4444-5555-666677778881
			column: SupplierName

		level Brand
			lineageTag: c3d4e5f6-3333-4444-5555-666677778882
			column: Brand

		level Product
			lineageTag: c3d4e5f6-3333-4444-5555-666677778883
			column: StockItemName

	partition Products = entity
		mode: directLake
		source
			entityName: Products
			schemaName: Gold
			expressionSource: DatabaseQuery

	annotation PBI_ResultType = Table

