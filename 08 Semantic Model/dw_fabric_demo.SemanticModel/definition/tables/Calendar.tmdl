/// Date dimension table containing calendar attributes for time-based analysis. Covers complete contiguous date range.
table Calendar
	lineageTag: 9d421a19-d9e7-4be2-8689-8aa2e0068ba7
	sourceLineageTag: [Gold].[Calendar]
	dataCategory: Time

	/// Calendar date value used for time-based filtering and analysis
	column Date
		dataType: dateTime
		formatString: General Date
		sourceProviderType: date
		lineageTag: e2d97c14-1a56-441e-8216-70ef617c594e
		sourceLineageTag: Date
		summarizeBy: none
		sourceColumn: Date

		annotation SummarizationSetBy = Automatic

	/// Day number within the month (1–31)
	column DayNum
		dataType: int64
		formatString: 0
		sourceProviderType: smallint
		lineageTag: e52b13ca-e718-4444-a93b-de76a65b13e3
		sourceLineageTag: DayNum
		summarizeBy: none
		sourceColumn: DayNum

		annotation SummarizationSetBy = Automatic

	column DayOfWeek
		dataType: string
		sourceProviderType: varchar(20)
		lineageTag: 87c69f76-d451-4ef8-8144-fe6bf00a62fe
		sourceLineageTag: DayOfWeek
		dataCategory: DayOfWeek
		summarizeBy: none
		sourceColumn: DayOfWeek
		sortByColumn: DayOfWeekNum

		annotation SummarizationSetBy = Automatic

	/// Hidden; numeric sort order for DayOfWeek (1=Sunday through 7=Saturday)
	column DayOfWeekNum
		dataType: int64
		isHidden
		formatString: 0
		sourceProviderType: smallint
		lineageTag: 3b1bbb35-9af3-444f-ba3f-f697cbc78ca9
		sourceLineageTag: DayOfWeekNum
		summarizeBy: none
		sourceColumn: DayOfWeekNum

		annotation SummarizationSetBy = Automatic

	/// Month name (e.g. January). Sorted by MonthNum
	column Month
		dataType: string
		sourceProviderType: varchar(20)
		lineageTag: 79c13f49-7a0c-43d0-824b-401165ccdafd
		sourceLineageTag: Month
		dataCategory: Months
		summarizeBy: none
		sourceColumn: Month
		sortByColumn: MonthNum

		annotation SummarizationSetBy = Automatic

	/// Hidden; numeric sort order for Month (1=January through 12=December)
	column MonthNum
		dataType: int64
		isHidden
		formatString: 0
		sourceProviderType: smallint
		lineageTag: fd73b285-d5f5-4eb8-a977-634267ce43d0
		sourceLineageTag: MonthNum
		summarizeBy: none
		sourceColumn: MonthNum

		annotation SummarizationSetBy = Automatic

	/// Hidden; numeric sort order for Quarter (1–4)
	column QuarterNum
		dataType: int64
		isHidden
		formatString: 0
		sourceProviderType: smallint
		lineageTag: e9118f56-d51c-401e-872f-3157115fa1f3
		sourceLineageTag: QuarterNum
		summarizeBy: none
		sourceColumn: QuarterNum

		annotation SummarizationSetBy = Automatic

	/// Calendar quarter label (e.g. Q1). Sorted by QuarterNum
	column Quarter
		dataType: string
		sourceProviderType: varchar(2)
		lineageTag: 7589e042-ee00-4e1d-98ea-c5458df209bd
		sourceLineageTag: Quarter
		dataCategory: QuarterOfYear
		summarizeBy: none
		sourceColumn: Quarter
		sortByColumn: QuarterNum

		annotation SummarizationSetBy = Automatic

	/// Calendar year (e.g. 2024)
	column Year
		dataType: int64
		formatString: 0
		sourceProviderType: smallint
		lineageTag: 097c733c-8380-4735-a759-bd135622cd2f
		sourceLineageTag: Year
		dataCategory: Years
		summarizeBy: none
		sourceColumn: Year

		annotation SummarizationSetBy = Automatic

	hierarchy 'Date Hierarchy'
		lineageTag: a1b2c3d4-1111-2222-3333-444455556666

		level Year
			lineageTag: a1b2c3d4-1111-2222-3333-444455556671
			column: Year

		level Quarter
			lineageTag: a1b2c3d4-1111-2222-3333-444455556672
			column: Quarter

		level Month
			lineageTag: a1b2c3d4-1111-2222-3333-444455556673
			column: Month

		level Date
			lineageTag: a1b2c3d4-1111-2222-3333-444455556674
			column: Date

	partition Calendar = entity
		mode: directLake
		source
			entityName: Calendar
			schemaName: Gold
			expressionSource: DatabaseQuery

	annotation PBI_ResultType = Table

